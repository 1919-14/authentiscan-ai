# =============================================================================
# AuthentiScan AI — Environment Configuration
#
# Copy this file to ".env" and fill in your values.
#   cp .env.example .env
#
# The app reads EVERYTHING LLM-related from these variables — you never need
# to touch any Python code to change the provider, base URL, or model.
# =============================================================================

# --- OpenCode Zen (LLM inference) --------------------------------------------
# Get a free API key at https://opencode.ai/auth  (OpenCode Zen dashboard)
OPENCODE_API_KEY=your_opencode_zen_api_key_here

# OpenCode Zen's OpenAI-compatible endpoint (usually no need to change this)
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Free-tier DeepSeek model served via OpenCode Zen.
# To switch models, just change this value (e.g. to another OpenCode Zen model id).
OPENCODE_MODEL=deepseek-v4-flash-free

# Seconds to wait for an LLM response before giving up
OPENCODE_TIMEOUT_SECONDS=30

# --- Django -------------------------------------------------------------------
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Uploads --------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
